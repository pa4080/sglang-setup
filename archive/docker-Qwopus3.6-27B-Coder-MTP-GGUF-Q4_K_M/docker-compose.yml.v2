services:
  llama-qwopus27b-q4km:
    container_name: llama-qwopus27b-q4km
    image: ghcr.io/ggml-org/llama.cpp:server-cuda
    network_mode: host
    restart: unless-stopped
    volumes:
      - /mnt/data/huggingface/Jackrong/Qwopus3.6-27B-Coder-MTP-GGUF:/models
      - /mnt/data/lmstudio/models/lmstudio-community/Qwen3.6-27B-GGUF:/models2
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: ['0']
              capabilities: [gpu]
    environment:
      - LLAMA_API_KEY=${LLAMA_API_KEY}
    command: >
      -m /models/Qwopus3.6-27B-Coder-MTP-Q4_K_M.gguf
      --host 0.0.0.0
      --port 10005
      -c 65536
      --n-gpu-layers 99
      --flash-attn on
      -ctk q8_0
      -ctv q8_0
      -ctkd q8_0
      -ctvd q8_0
      -b 4096
      -ub 1024
      --spec-type draft-mtp
      --spec-draft-n-max 2
      --mmproj /models2/mmproj-Qwen3.6-27B-BF16.gguf
      --image-min-tokens 1024
      --context-shift
